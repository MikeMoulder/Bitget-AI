# --- Brain: OpenRouter (required to run the agent loop) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-3.1-flash-lite   # any OpenRouter model with tool calling

# --- Bitget DEMO (paper) trading keys — only needed for `npm run agent -- --live` ---
# Create at bitget.com → Settings → API Management (enable Read + Trade).
# Use a DEMO/paper key; the server sends the paptrading:1 header.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# --- Agent config (optional) ---
AGENT_SYMBOL=BTCUSDT
AGENT_RISK_APPETITE=balanced        # conservative | balanced | aggressive

# --- Risk caps enforced by the bridge (hard limits the model cannot exceed) ---
AGENT_ALLOWED_SYMBOLS=BTCUSDT
AGENT_MAX_ORDER_SIZE=0.01
AGENT_MAX_LEVERAGE=3
